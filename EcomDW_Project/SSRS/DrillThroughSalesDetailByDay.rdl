  <DataSets>
    <DataSet Name="dsSalesDetailByDay">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Category">
            <Value>=Parameters!Category.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@State">
            <Value>=Parameters!State.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Region">
            <Value>=Parameters!Region.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProductId">
            <Value>=Parameters!ProductId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    SaleDate,
    StoreName,
    City,
    Units,
    Revenue,
    SourceFile,
    LoadDttm
FROM rpt.vw_Sales
WHERE
    -- Dates (single values)
    (@StartDate IS NULL OR SaleDate &gt;= @StartDate)
AND (@EndDate   IS NULL OR SaleDate &lt;= @EndDate)

    -- Multi-select filters (NO NULL checks)
AND Category IN (@Category)
AND Region   IN (@Region)
AND [State]  IN (@State)
AND (@ProductId IS NULL OR ProductId = @ProductId);</CommandText>
      </Query>
      <Fields>
        <Field Name="SaleDate">
          <DataField>SaleDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="StoreName">
          <DataField>StoreName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="City">
          <DataField>City</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Units">
          <DataField>Units</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Revenue">
          <DataField>Revenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SourceFile">
          <DataField>SourceFile</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LoadDttm">
          <DataField>LoadDttm</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsPickRegion">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT Region
FROM rpt.vw_Sales
WHERE Region IS NOT NULL
ORDER BY Region;</CommandText>
      </Query>
      <Fields>
        <Field Name="Region">
          <DataField>Region</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsPickState">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Region">
            <Value>=Parameters!Region.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT [State]
FROM rpt.vw_Sales
WHERE Region IN (@Region)
  AND [State] IS NOT NULL
ORDER BY [State];</CommandText>
      </Query>
      <Fields>
        <Field Name="State">
          <DataField>State</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsPickProductid">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Category">
            <Value>=Parameters!Category.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Region">
            <Value>=Parameters!Region.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@State">
            <Value>=Parameters!State.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
    ProductId,
    ProductName
FROM rpt.vw_Sales
WHERE Category IN (@Category)
  AND Region   IN (@Region)
  AND [State]  IN (@State)
  AND ProductId IS NOT NULL
ORDER BY ProductName, ProductId;</CommandText>
      </Query>
      <Fields>
        <Field Name="ProductId">
          <DataField>ProductId</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ProductName">
          <DataField>ProductName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsPickCategory">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT Category
FROM rpt.vw_Sales
WHERE Category IS NOT NULL
ORDER BY Category;</CommandText>
      </Query>
      <Fields>
        <Field Name="Category">
          <DataField>Category</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>

    <DataSet Name="dsPickCategory">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT
    Category AS CategoryValue,
    Category AS CategoryLabel
FROM rpt.vw_Sales
WHERE Category IS NOT NULL
ORDER BY Category;
</CommandText>
      </Query>
      <Fields>
        <Field Name="CategoryValue">
          <DataField>CategoryValue</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CategoryLabel">
          <DataField>CategoryLabel</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsPickState">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Region">
            <Value>=Parameters!Region.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
    s.[State] AS StateValue,
    s.[State] AS StateLabel
FROM rpt.vw_Sales s
WHERE s.[State] IS NOT NULL
  AND s.Region IN (@Region)
ORDER BY s.[State];</CommandText>
      </Query>
      <Fields>
        <Field Name="StateValue">
          <DataField>StateValue</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="StateLabel">
          <DataField>StateLabel</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsPickRegion">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT
    Region AS RegionValue,
    Region AS RegionLabel
FROM rpt.vw_Sales
WHERE Region IS NOT NULL
ORDER BY Region;</CommandText>
      </Query>
      <Fields>
        <Field Name="RegionValue">
          <DataField>RegionValue</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="RegionLabel">
          <DataField>RegionLabel</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsPickStore">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Region">
            <Value>=Parameters!Region.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@State">
            <Value>=Parameters!State.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
    s.StoreName AS StoreValue,
    s.StoreName AS StoreLabel
FROM rpt.vw_Sales s
WHERE s.StoreName IS NOT NULL
  AND s.Region IN (@Region)
  AND s.[State] IN (@State)
ORDER BY s.StoreName;
</CommandText>
      </Query>
      <Fields>
        <Field Name="StoreValue">
          <DataField>StoreValue</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="StoreLabel">
          <DataField>StoreLabel</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsPickBrand">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Category">
            <Value>=Parameters!Category.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Region">
            <Value>=Parameters!Region.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@State">
            <Value>=Parameters!State.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@StoreName">
            <Value>=Parameters!StoreName.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
    s.Brand AS BrandValue,
    s.Brand AS BrandLabel
FROM rpt.vw_Sales s
WHERE s.Brand IS NOT NULL
  AND s.Category  IN (@Category)
  AND s.Region    IN (@Region)
  AND s.[State]   IN (@State)
  AND s.StoreName IN (@StoreName)
ORDER BY s.Brand;
</CommandText>
      </Query>
      <Fields>
        <Field Name="BrandValue">
          <DataField>BrandValue</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BrandLabel">
          <DataField>BrandLabel</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsRunMetadata">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>;WITH LastRun AS
(
    SELECT TOP (1) RunId
    FROM etl.RunLog
    ORDER BY LoggedAt DESC
),
R AS
(
    SELECT rl.*
    FROM etl.RunLog rl
    WHERE rl.RunId = (SELECT RunId FROM LastRun)
)
SELECT
    LastRefreshed =
        MAX(LoggedAt),

    SourceFilesLoaded =
        COUNT(DISTINCT CASE WHEN SourceFile IS NOT NULL AND LTRIM(RTRIM(SourceFile)) &lt;&gt; '' THEN SourceFile END),

    RowsStaged =
        MAX(CASE WHEN StepName = 'Loaded file to stg.SalesRaw' THEN [RowCount] END),

    FactRowsFullReload =
        MAX(CASE WHEN StepName = 'Loaded dw.FactSales (full reload)' THEN [RowCount] END),

    FactInsertRows =
        MAX(CASE WHEN StepName IN ('FactSales INSERT','Fact insert (param)') THEN [RowCount] END),

    FactUpdateRows =
        MAX(CASE WHEN StepName IN ('FactSales UPDATE','Fact update (param)') THEN [RowCount] END)
FROM R;
</CommandText>
      </Query>
      <Fields>
        <Field Name="LastRefreshed">
          <DataField>LastRefreshed</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="SourceFilesLoaded">
          <DataField>SourceFilesLoaded</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="RowsStaged">
          <DataField>RowsStaged</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="FactRowsFullReload">
          <DataField>FactRowsFullReload</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="FactInsertRows">
          <DataField>FactInsertRows</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="FactUpdateRows">
          <DataField>FactUpdateRows</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>

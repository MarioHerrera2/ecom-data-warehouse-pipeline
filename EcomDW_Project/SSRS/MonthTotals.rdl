  <Code>Public Function SmartList(ByVal v As Object, Optional ByVal allToken As String = "ALL", Optional ByVal maxItems As Integer = 5) As String

    If v Is Nothing Then Return "All"

    Dim arr() As Object

    ' Multi-value params come in as Object()
    If TypeOf v Is Object() Then
        arr = CType(v, Object())
    Else
        arr = New Object() { v }
    End If

    If arr.Length = 0 Then Return "All"

    ' If user selected your hardcoded ALL token, treat as All
    For Each o As Object In arr
        If o IsNot Nothing AndAlso String.Compare(CStr(o), allToken, True) = 0 Then
            Return "All"
        End If
    Next

    ' If small list, show values
    If arr.Length &lt;= maxItems Then
        Dim parts As New System.Collections.Generic.List(Of String)
        For Each o As Object In arr
            If o IsNot Nothing Then parts.Add(CStr(o))
        Next
        Return String.Join(", ", parts.ToArray())
    End If

    ' Otherwise summarize
    Return arr.Length.ToString() &amp; " selected"

End Function</Code>

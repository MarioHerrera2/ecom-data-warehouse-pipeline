  <DataSets>
    <DataSet Name="dsSales">
      <Query>
        <DataSourceName>DS_EcomDW</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Category">
            <Value>=Parameters!Category.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@State">
            <Value>=Parameters!State.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Region">
            <Value>=Parameters!Region.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    SaleDate,
    [Year],
    MonthName,

    Category,
    Brand,
    ProductName,
    

    Region,
    [State],
    StoreName,
    

    Units,
    Revenue
FROM rpt.vw_Sales
WHERE (@StartDate IS NULL OR SaleDate &gt;= @StartDate)
  AND (@EndDate   IS NULL OR SaleDate &lt;= @EndDate)
 AND Category IN (@Category)
  AND State in (@State)
  AND Region in (@Region);</CommandText>
      </Query>
      <Fields>
        <Field Name="SaleDate">
          <DataField>SaleDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="Year">
          <DataField>Year</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="MonthName">
          <DataField>MonthName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Category">
          <DataField>Category</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Brand">
          <DataField>Brand</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ProductName">
          <DataField>ProductName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Region">
          <DataField>Region</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="State">
          <DataField>State</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="StoreName">
          <DataField>StoreName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Units">
          <DataField>Units</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Revenue">
          <DataField>Revenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsCategory">
      <Query>
        <DataSourceName>DS_EcomDW</DataSourceName>
        <CommandText>SELECT DISTINCT Category
FROM rpt.vw_Sales
WHERE Category IS NOT NULL
ORDER BY Category;
</CommandText>
      </Query>
      <Fields>
        <Field Name="Category">
          <DataField>Category</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsState">
      <Query>
        <DataSourceName>DS_EcomDW</DataSourceName>
        <CommandText>SELECT DISTINCT State
FROM rpt.vw_Sales
WHERE State IS NOT NULL
ORDER BY State;
</CommandText>
      </Query>
      <Fields>
        <Field Name="State">
          <DataField>State</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsPickRegion">
      <Query>
        <DataSourceName>DS_EcomDW</DataSourceName>
        <CommandText>SELECT DISTINCT Region

FROM rpt.vw_Sales

WHERE Region IS NOT NULL

ORDER BY Region;</CommandText>
      </Query>
      <Fields>
        <Field Name="Region">
          <DataField>Region</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
